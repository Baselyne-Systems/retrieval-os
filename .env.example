# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=retrieval-os
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://retrieval_os:retrieval_os@localhost:5432/retrieval_os
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=retrieval-os
S3_REGION=us-east-1

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_HTTP_PORT=6333
# QDRANT_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true
OTEL_SERVICE_NAME=retrieval-os-api

# ── Optional external API keys ────────────────────────────────────────────────
# COHERE_API_KEY=

# ── Auth & Rate limiting ───────────────────────────────────────────────────────
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT_RPM=60

# ── Background task intervals ─────────────────────────────────────────────────
ROLLBACK_WATCHDOG_INTERVAL_SECONDS=30
ROLLOUT_STEPPER_INTERVAL_SECONDS=10
EVAL_JOB_POLL_INTERVAL_SECONDS=5
COST_AGGREGATOR_INTERVAL_SECONDS=3600
INGESTION_JOB_POLL_INTERVAL_SECONDS=5
